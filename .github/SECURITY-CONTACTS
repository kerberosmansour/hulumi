# SECURITY CONTACTS for Hulumi
#
# This file follows the Kubernetes SECURITY-CONTACTS convention:
# https://github.com/kubernetes/community/blob/master/contributors/devel/sig-release/security-release-process.md#disclosures
#
# It documents who to contact for security-related matters and what
# disclosure paths are available. SECURITY.md (in the repo root) holds
# the full disclosure policy, supported-versions table, and SLSA
# verification instructions.

primary_contacts:
  - github_login: kerberosmansour
    role: Maintainer / project lead
    handles:
      - GitHub: https://github.com/kerberosmansour

# Preferred reporting path: GitHub Security Advisories.
# This creates a private fork of the repo and lets us coordinate the
# fix without public disclosure.
preferred_reporting_url: https://github.com/kerberosmansour/hulumi/security/advisories/new

# Email reporting path.
#
# This project intentionally does NOT publish a security@ email address.
# All vulnerability reports go through GitHub Security Advisories
# (preferred_reporting_url above). If GHSA is unavailable, contact the
# maintainer through the public GitHub profile.
email_contacts: []

# PGP / age key for encrypted communication.
#
# No PGP key is published at this time. If you need to send encrypted
# material, request a key via the Security Advisory path and the
# maintainer will publish one. A public PGP fingerprint will be added
# here when one is generated.
pgp_keys: []

# Coordinated-disclosure window
#
# The SECURITY.md policy commits to:
#   - acknowledgement within 3 business days
#   - triage within 7 business days
#   - fix plan or status update within 14 business days
#   - coordinated disclosure after a fix or agreed mitigation is available
disclosure_window_acknowledge_business_days: 3
disclosure_window_triage_business_days: 7
disclosure_window_fix_plan_business_days: 14

# Out of scope
#
# Forks and mirrors of Hulumi are unofficial. The only authoritative
# repository is `kerberosmansour/hulumi`. Reports against forks should
# go to the fork's maintainers; typosquatting reports should also go to
# the registries (npmjs.com for `@hulumi/*` lookalikes).
out_of_scope:
  - forks-of-this-repo
  - npm-typosquats (report to npmjs.com support + this contact)

# Reference: SECURITY.md (full policy)
#
# https://github.com/kerberosmansour/hulumi/blob/main/SECURITY.md
