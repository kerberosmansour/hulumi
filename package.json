{
  "name": "hulumi",
  "version": "0.1.0",
  "private": true,
  "description": "Hardened Pulumi for the AI-agent era — baseline components, CrossGuard pack, drift classifier, Claude Code skill pack.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "skills/*",
    "tests/*"
  ],
  "scripts": {
    "build": "pnpm -r --stream build",
    "test": "pnpm -r --stream test",
    "test:baseline": "pnpm --filter @hulumi/baseline test",
    "test:policies": "pnpm --filter @hulumi/policies test",
    "lint": "pnpm -r --stream lint && pnpm run lint:license-boundary",
    "lint:license-boundary": "node scripts/license-boundary-lint.mjs",
    "lint:exact-pin-guard": "node scripts/exact-pin-guard.mjs",
    "typecheck": "pnpm -r --stream typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
