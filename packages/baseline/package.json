{
  "name": "@hulumi/baseline",
  "version": "0.1.0",
  "description": "Hardened Pulumi baseline components for AWS — SecureBucket and forthcoming AccountFoundation.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "default": "./dist/aws/index.js"
    },
    "./mappings": {
      "types": "./dist/mappings/index.d.ts",
      "default": "./dist/mappings/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
