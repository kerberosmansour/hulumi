{
  "name": "@hulumi/baseline",
  "version": "1.5.0",
  "description": "Hardened Pulumi baseline components for AWS and GitHub — SecureBucket, AccountFoundation, AWS organization guardrails, secure primitives, detection foundations, SecureRepository, OrgFoundation. SLSA Build L3 attestation on every release.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kerberosmansour/hulumi.git",
    "directory": "packages/baseline"
  },
  "bugs": {
    "url": "https://github.com/kerberosmansour/hulumi/issues"
  },
  "homepage": "https://github.com/kerberosmansour/hulumi/tree/main/packages/baseline#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "default": "./dist/aws/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "default": "./dist/github/index.js"
    },
    "./mappings": {
      "types": "./dist/mappings/index.d.ts",
      "default": "./dist/mappings/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/aws": "^7.27.0",
    "@pulumi/github": "^6.13.1",
    "@pulumi/pulumi": "^3.232.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.32.0",
    "@pulumi/github": "6.14.0",
    "@pulumi/pulumi": "3.245.0",
    "@types/node": "20.19.43",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
