    "@aws-sdk/credential-providers": "3.1037.0",
    "p-timeout": "7.0.1",
    "simple-git": "3.36.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@types/node": "20.19.39",
    "memfs": "4.17.2",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
