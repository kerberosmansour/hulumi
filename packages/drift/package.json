{
  "name": "@hulumi/drift",
  "version": "1.5.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Local-first drift classifier and live posture validator — distinguishes provider-API churn from console break-glass from genuine IaC drift, then renders read-only live posture findings as JSON, Markdown, and SARIF. Verdict logic mirrors HulumiDrift.tla HardenedVerdict exactly. Cache schema v2.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kerberosmansour/hulumi.git",
    "directory": "packages/drift"
  },
  "bugs": {
    "url": "https://github.com/kerberosmansour/hulumi/issues"
  },
  "homepage": "https://github.com/kerberosmansour/hulumi/tree/main/packages/drift#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hulumi": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/pulumi": "^3.232.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "3.1045.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1053.0",
    "@aws-sdk/client-s3": "3.1047.0",
    "@aws-sdk/client-sts": "3.1045.0",
    "@aws-sdk/credential-providers": "3.1045.0",
    "p-timeout": "7.0.1",
    "simple-git": "3.36.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.27.0",
    "@pulumi/pulumi": "3.232.0",
    "@types/node": "20.19.41",
    "memfs": "4.57.2",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
