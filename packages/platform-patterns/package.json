{
  "name": "@hulumi/platform-patterns",
  "version": "1.3.0",
  "description": "Cross-provider Pulumi patterns for Cloudflare edge ingress, AWS deployment identity, and GitHub deployment repositories.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kerberosmansour/hulumi.git",
    "directory": "packages/platform-patterns"
  },
  "bugs": {
    "url": "https://github.com/kerberosmansour/hulumi/issues"
  },
  "homepage": "https://github.com/kerberosmansour/hulumi/tree/main/packages/platform-patterns#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hulumi/baseline": "workspace:*"
  },
  "peerDependencies": {
    "@pulumi/aws": "7.27.0",
    "@pulumi/cloudflare": "6.15.0",
    "@pulumi/github": "6.13.1",
    "@pulumi/pulumi": "3.232.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.27.0",
    "@pulumi/cloudflare": "6.15.0",
    "@pulumi/github": "6.13.1",
    "@pulumi/pulumi": "3.232.0",
    "@types/node": "20.19.41",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
