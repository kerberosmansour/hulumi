{
  "name": "@hulumi/policies",
  "version": "1.2.0",
  "private": true,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Pulumi CrossGuard policy packs for AWS and GitHub: HulumiHardeningPack + CisV5Pack on the AWS side; HulumiGithubHardeningPack (H1+H2+G_OIDC_1) + CisGithubV1Pack (placeholder pending CIS WorkBench) on the GitHub side. SLSA Build L3 attestation on every release.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aws/packs/hulumi-hardening": {
      "types": "./dist/aws/packs/hulumi-hardening.d.ts",
      "default": "./dist/aws/packs/hulumi-hardening.js"
    },
    "./aws/packs/cis-v5": {
      "types": "./dist/aws/packs/cis-v5.d.ts",
      "default": "./dist/aws/packs/cis-v5.js"
    },
    "./github/packs/hulumi-hardening": {
      "types": "./dist/github/packs/hulumi-hardening.d.ts",
      "default": "./dist/github/packs/hulumi-hardening.js"
    },
    "./github/packs/cis-v1": {
      "types": "./dist/github/packs/cis-v1.d.ts",
      "default": "./dist/github/packs/cis-v1.js"
    }
  },
  "files": [
    "dist/",
    "PulumiPolicy.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0",
    "@pulumi/policy": "1.20.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0",
    "@pulumi/policy": "1.20.0",
    "@types/node": "20.19.39",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
