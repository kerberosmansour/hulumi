{
  "name": "@hulumi/policies",
  "version": "1.5.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Pulumi CrossGuard policy packs for AWS, GitHub, Kubernetes, Cloudflare, and deployment governance. Includes HulumiHardeningPack, HulumiAwsOrgHardeningPack, state/backend/primitive/detection rules, GitHub packs, EKS packs, and platform governance. SLSA Build L3 attestation on every release.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kerberosmansour/hulumi.git",
    "directory": "packages/policies"
  },
  "bugs": {
    "url": "https://github.com/kerberosmansour/hulumi/issues"
  },
  "homepage": "https://github.com/kerberosmansour/hulumi/tree/main/packages/policies#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aws/packs/hulumi-hardening": {
      "types": "./dist/aws/packs/hulumi-hardening.d.ts",
      "default": "./dist/aws/packs/hulumi-hardening.js"
    },
    "./aws/packs/cis-v5": {
      "types": "./dist/aws/packs/cis-v5.d.ts",
      "default": "./dist/aws/packs/cis-v5.js"
    },
    "./aws-org/packs/hulumi-aws-org-hardening": {
      "types": "./dist/aws-org/packs/hulumi-aws-org-hardening.d.ts",
      "default": "./dist/aws-org/packs/hulumi-aws-org-hardening.js"
    },
    "./github/packs/hulumi-hardening": {
      "types": "./dist/github/packs/hulumi-hardening.d.ts",
      "default": "./dist/github/packs/hulumi-hardening.js"
    },
    "./github/packs/cis-v1": {
      "types": "./dist/github/packs/cis-v1.d.ts",
      "default": "./dist/github/packs/cis-v1.js"
    },
    "./cloudflare/packs/hulumi-hardening": {
      "types": "./dist/cloudflare/packs/hulumi-hardening.d.ts",
      "default": "./dist/cloudflare/packs/hulumi-hardening.js"
    },
    "./platform/packs/origin-bypass": {
      "types": "./dist/platform/packs/origin-bypass.d.ts",
      "default": "./dist/platform/packs/origin-bypass.js"
    },
    "./platform/packs/deployment-governance": {
      "types": "./dist/platform/packs/deployment-governance.d.ts",
      "default": "./dist/platform/packs/deployment-governance.js"
    }
  },
  "files": [
    "dist/",
    "PulumiPolicy.yaml"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/aws": "^7.27.0",
    "@pulumi/policy": "^1.20.0",
    "@pulumi/pulumi": "^3.232.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.33.0",
    "@pulumi/policy": "1.21.0",
    "@pulumi/pulumi": "3.246.0",
    "@types/node": "20.19.42",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
