{
  "name": "@hulumi/policies",
  "version": "0.1.0",
  "description": "Pulumi CrossGuard policy packs: HulumiHardeningPack enforces Hulumi invariants; CisV5Pack (stub) is the seed of the full CIS AWS v5.0.0 pack.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aws/packs/hulumi-hardening": {
      "types": "./dist/aws/packs/hulumi-hardening.d.ts",
      "default": "./dist/aws/packs/hulumi-hardening.js"
    },
    "./aws/packs/cis-v5": {
      "types": "./dist/aws/packs/cis-v5.d.ts",
      "default": "./dist/aws/packs/cis-v5.js"
    }
  },
  "files": [
    "dist/",
    "PulumiPolicy.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0",
    "@pulumi/policy": "1.20.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@pulumi/aws": "7.27.0",
    "@pulumi/policy": "1.20.0",
    "@types/node": "20.19.39",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
